# ── Required ──────────────────────────────────────────────────────────
# ZenMux AI API key for LLM features (nudge messages, reports, queries)
ZENMUX_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────
# ZenMux API endpoint (default: https://zenmux.ai/api/v1)
ZENMUX_BASE_URL=https://zenmux.ai/api/v1

# ZenMux model name (default: z-ai/glm-5.2-free)
ZENMUX_MODEL=z-ai/glm-5.2-free

# CORS allowed origins (comma-separated, default: http://localhost:3000,http://127.0.0.1:3000)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Path to raw CSV data file (default: jan to may police violation_anonymized791b166.csv)
DISPATCHMIND_CSV=jan to may police violation_anonymized791b166.csv

# Path to junction coordinates JSON (default: data/external/junction_coords.json)
DISPATCHMIND_COORDS=data/external/junction_coords.json

# Path to cache parquet file (default: data/processed/dispatchmind_scored.parquet)
DISPATCHMIND_CACHE=data/processed/dispatchmind_scored.parquet

# Mappls API key (frontend: VITE_MAPPLS_API_KEY)
VITE_MAPPLS_API_KEY=

# ── BTP Dispatch Communications (Optional) ────────────────────────────
# Note for Hackathon Judges: 
# The application is currently running in "Local Dispatch Mode" 
# which outputs webhooks and SMS alerts securely to the terminal.
# To enable real SMS/WhatsApp dispatch to BTP Officers, uncomment below:
# TWILIO_ACCOUNT_SID=your_twilio_sid_here
# TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
# TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
# TWILIO_PHONE_NUMBER=+1234567890

# ── Database Setup ────────────────────────────────────────────────────
# Default SQLite for local demo, replace with Postgres for production
DATABASE_URL=sqlite:///./btp_data.db

# PostgreSQL connection pool settings (only used when DATABASE_URL is postgresql://...)
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10
# DB_POOL_TIMEOUT=30
